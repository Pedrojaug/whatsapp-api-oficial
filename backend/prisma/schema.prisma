datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String    // Hashed password
  name      String?
  role      String    @default("USER")
  accounts  Account[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Account {
  id            String     @id @default(uuid())
  name          String
  wabaId        String     // WhatsApp Business Account ID
  phoneNumberId String     // Phone Number ID
  accessToken   String     // System User Token
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  templates     Template[]
  messages      Message[]
  contactLists  ContactList[]
  mediaAssets   MediaAsset[]

  @@unique([userId, name])
}

model Template {
  id         String   @id @default(uuid())
  metaId     String?  @unique // ID returned by Meta API
  name       String
  language   String   @default("pt_BR")
  category   String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  components Json     // Holds the structure: body, headers, buttons, etc.
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountId, name])
}

model Message {
  id           String   @id @default(uuid())
  wamid        String?  @unique // WhatsApp Message ID (e.g. wamid.HBgNNTUxM...)
  to           String   // Recipient phone number (e.g. 5511999999999)
  status       String   @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  errorMessage String?
  templateName String
  variables    Json?    // Sent parameters (variables arrays/objects)
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime?
  retryCount   Int      @default(0)
  nextRetryAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactList {
  id        String    @id @default(uuid())
  name      String
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([accountId, name])
}

model Contact {
  id            String      @id @default(uuid())
  name          String?
  phone         String      // e.g. "5583986241167"
  variables     Json?       // Dynamic fields like ["João", "order_123"]
  contactListId String
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model MediaAsset {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
