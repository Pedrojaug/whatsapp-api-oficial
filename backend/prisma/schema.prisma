datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String?   // Nullable — Google OAuth users have no password
  name      String?
  role      String    @default("USER")
  googleId  String?   @unique
  avatarUrl String?
  emailVerified              Boolean   @default(false)
  verificationToken          String?   @unique
  verificationTokenExpiry    DateTime?
  resetPasswordToken         String?   @unique
  resetPasswordTokenExpiry   DateTime?
  onboardingCompleted        Boolean   @default(false)
  planTier                   String    @default("free")
  accounts       Account[]
  sharedAccounts AccountShare[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Account {
  id            String     @id @default(uuid())
  name          String
  wabaId        String     // WhatsApp Business Account ID
  phoneNumberId String     // Phone Number ID
  accessToken   String     // System User Token
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  templates        Template[]
  messages         Message[]
  contactLists     ContactList[]
  mediaAssets      MediaAsset[]
  whatsappContacts WhatsAppContact[]
  optOuts          OptOut[]
  trackedLinks     TrackedLink[]
  apiKeys          ApiKey[]
  campaigns        Campaign[]
  shares           AccountShare[]

  @@unique([userId, name])
}

model AccountShare {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // MEMBER = acesso total exceto excluir conta/gerenciar shares
  createdAt DateTime @default(now())

  @@unique([accountId, userId])
  @@index([userId])
}


model Template {
  id         String   @id @default(uuid())
  metaId     String?  @unique // ID returned by Meta API
  name       String
  language   String   @default("pt_BR")
  category   String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  components Json     // Holds the structure: body, headers, buttons, etc.
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountId, name])
}

model Message {
  id           String   @id @default(uuid())
  wamid        String?  @unique // WhatsApp Message ID (e.g. wamid.HBgNNTUxM...)
  to           String   // Recipient phone number (e.g. 5511999999999)
  status       String   @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED, RECEIVED
  direction    String   @default("OUTGOING") // OUTGOING (nós enviamos) ou INCOMING (cliente enviou)
  messageType  String   @default("TEMPLATE") // TEMPLATE, TEXT, IMAGE, VIDEO, DOCUMENT
  body         String?  // Conteúdo textual livre da mensagem
  mediaUrl     String?  // URL de mídias enviadas/recebidas
  errorMessage String?
  templateName String?  // Agora opcional para suportar mensagens de texto livre
  variables    Json?    // Sent parameters (variables arrays/objects)
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime?
  retryCount   Int      @default(0)
  nextRetryAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([accountId, to, createdAt])
  @@index([accountId, status, createdAt])
  @@index([status, scheduledAt, nextRetryAt])
}

model ContactList {
  id        String    @id @default(uuid())
  name      String
  tags      String[]  @default([])
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([accountId, name])
}

model Contact {
  id            String      @id @default(uuid())
  name          String?
  phone         String      // e.g. "5583986241167"
  variables     Json?       // Dynamic fields like ["João", "order_123"]
  contactListId String
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model WhatsAppContact {
  id          String   @id @default(uuid())
  phone       String   // Número normalizado (13 dígitos BR)
  profileName String?  // Nome de perfil do WhatsApp (contacts[].profile.name)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, phone])
}

model MediaAsset {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  fileData  String?  // Armazena o base64 do arquivo para persistência no Render
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrackedLink {
  id          String    @id @default(uuid())
  shortCode   String    @unique
  originalUrl String
  label       String?
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clicks      Int       @default(0)
  lastClickAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([accountId])
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([accountId])
}

model Campaign {
  id            String        @id @default(uuid())
  name          String
  accountId     String
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactListId String?
  templateName  String
  variables     Json?
  mediaUrl      String?
  status        String        @default("DRAFT")
  scheduleType  String        // ONCE, DAILY, WEEKLY, MONTHLY
  scheduleTime  String?       // "HH:MM" UTC
  scheduleDays  Int[]         @default([])
  scheduleDate  DateTime?
  nextRunAt     DateTime?
  lastRunAt     DateTime?
  runCount      Int           @default(0)
  runs          CampaignRun[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([accountId])
  @@index([status, nextRunAt])
}

model CampaignRun {
  id            String    @id @default(uuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status        String    @default("RUNNING")
  messagesSent  Int       @default(0)
  contactsTotal Int       @default(0)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?

  @@index([campaignId])
}

model OptOut {
  id        String   @id @default(uuid())
  phone     String
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reason    String   @default("USER_REQUEST") // USER_REQUEST, MANUAL, KEYWORD
  createdAt DateTime @default(now())

  @@unique([phone, accountId])
  @@index([accountId])
}
