# ─── Banco de Dados ────────────────────────────────────────────────────────────
# URL de conexão PostgreSQL (ex: Neon, Supabase, Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3001"

# ─── Segurança (OBRIGATÓRIO — servidor não inicia sem estas) ───────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="sua-chave-jwt-secreta-minimo-32-caracteres"

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="sua-chave-aes-256-de-32-caracteres"

# ─── Integração Meta / WhatsApp ────────────────────────────────────────────────
FACEBOOK_APP_ID=SEU_APP_ID_AQUI
FACEBOOK_APP_SECRET=SEU_APP_SECRET_AQUI

# Token para validação de webhooks da Meta (você define este valor)
WEBHOOK_VERIFY_TOKEN="um-token-secreto-para-verificar-webhooks"

# ─── Integração n8n (opcional) ─────────────────────────────────────────────────
N8N_SDR_WEBHOOK_URL="https://seu-n8n.dominio.com/webhook/SEU_WEBHOOK_ID"

# Chave de API para autenticar requisições vindas do n8n (você define)
N8N_API_KEY="uma-chave-api-secreta-para-o-n8n"
