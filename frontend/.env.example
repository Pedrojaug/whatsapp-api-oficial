# ─── URL da API Backend ────────────────────────────────────────────────────────
# Em desenvolvimento: http://localhost:3001/api
# Em produção: URL pública do seu backend (ex: Render, Railway)
VITE_API_BASE_URL=http://localhost:3001/api

# ─── Integração Facebook OAuth ─────────────────────────────────────────────────
# O mesmo FACEBOOK_APP_ID configurado no backend
VITE_FACEBOOK_APP_ID=SEU_APP_ID_AQUI
